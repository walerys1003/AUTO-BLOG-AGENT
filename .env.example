# =================================================================
# MasterContentAI - Environment Variables Template
# Copy this to .env and fill with real values for local development
# =================================================================

# Flask
SESSION_SECRET=change-me-to-a-long-random-string
DATABASE_URL=sqlite:///zyga.db

# Admin (legacy single-user fallback - new system uses DB users)
ADMIN_LOGIN=admin
ADMIN_PASSWORD=change-me

# AI - OpenRouter (primary)
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# AI Models
DEFAULT_TOPIC_MODEL=anthropic/claude-haiku-4.5
DEFAULT_CONTENT_MODEL=anthropic/claude-haiku-4.5
DEFAULT_SOCIAL_MODEL=anthropic/claude-haiku-4.5

# Images
UNSPLASH_API_KEY=
BING_SEARCH_API_KEY=
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# SEO
SERPAPI_KEY=

# Social Media
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
TWITTER_API_KEY=
TWITTER_API_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Application
ARTICLES_PER_DAY_PER_BLOG=3
ARTICLE_MIN_LENGTH=1200
ARTICLE_MAX_LENGTH=1600
PUBLISHING_TIMES=08:00,12:00,16:00,20:00
LOG_RETENTION_DAYS=30

# Production safety
USE_MOCK_ADAPTER=false
